# 至少 16 个字符；请在部署前替换为随机值。
ADMIN_TOKEN=

# 至少 32 个字符；更换后将无法解密已有站点令牌，请妥善备份。
APP_SECRET=

# PostgreSQL 用户密码；Compose 用原始值初始化数据库。
POSTGRES_PASSWORD=

# 使用与上方相同的密码，但 URI 用户信息中的保留字符必须百分号编码。
# Compose 网络内的数据库主机名固定为 postgres。
DATABASE_URL=

# 以下变量均可选；留空时请删除对应行并使用括号内默认值。
NODE_ENV=production
HOST=0.0.0.0
PORT=4180
POSTGRES_PORT=5432
DATABASE_POOL_MAX=5
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_STATEMENT_TIMEOUT_MS=15000
HTTP_TIMEOUT_MS=10000
MAX_RESPONSE_BYTES=1048576
ALLOW_PRIVATE_SITES=false
ALLOW_INSECURE_HTTP=false

# Go 运行时软限制；默认 96MiB，容器硬限制仍为 128 MiB。
GOMEMLIMIT=96MiB

# Docker/Go 构建加速；均保持上游镜像 digest 不变，可按网络环境替换或删除。
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:18-alpine@sha256:9a8afca54e7861fd90fab5fdf4c42477a6b1cb7d293595148e674e0a3181de15
NODE_BUILD_IMAGE=docker.m.daocloud.io/library/node:24-bookworm-slim@sha256:6f7b03f7c2c8e2e784dcf9295400527b9b1270fd37b7e9a7285cf83b6951452d
GO_BUILD_IMAGE=docker.m.daocloud.io/library/golang:1.26.5-bookworm@sha256:1ecb7edf62a0408027bd5729dfd6b1b8766e578e8df93995b225dfd0944eb651
RUNTIME_IMAGE=gcr.nju.edu.cn/distroless/static-debian12:nonroot@sha256:aef9602f8710ec12bde19d593fed1f76c708531bb7aba205110f1029786ead7b
NPM_REGISTRY=https://registry.npmmirror.com
GOPROXY=https://goproxy.cn,direct

# 可选：低内存机器的 Go 构建限制；留空使用 Go 默认值。800 MiB 主机可设为
# GO_BUILD_GOMAXPROCS=1、GO_BUILD_GOMEMLIMIT=384MiB、
# GO_BUILD_FLAGS=-p=1 -tags=nomsgpack。APIHub 不提供 MessagePack 接口。
GO_BUILD_GOMAXPROCS=
GO_BUILD_GOMEMLIMIT=
GO_BUILD_FLAGS=
