{
  "manifest_version": 3,
  "name": "APIHub 浏览器伴侣",
  "version": "0.1.0",
  "description": "在本机 Chrome 会话中执行 APIHub 浏览器签到任务，不上传 Cookie 或本地存储。",
  "permissions": ["alarms", "storage", "tabs", "windows"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html" },
  "content_scripts": [{
    "matches": ["http://*/*", "https://*/*"],
    "js": ["page-agent.js"],
    "run_at": "document_idle"
  }]
}
